{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/settings", "destination": "/api/index.py" },
    { "source": "/export/:path*", "destination": "/api/index.py" },
    { "source": "/kb", "destination": "/api/index.py" },
    { "source": "/kb/:path*", "destination": "/api/index.py" },
    { "source": "/kb-drafts/:path*", "destination": "/api/index.py" },
    { "source": "/((?!api/|settings|export/|kb|kb-drafts/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/run-ingestion",
      "schedule": "0 6 * * *"
    }
  ]
}
